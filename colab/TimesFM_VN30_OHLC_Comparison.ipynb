        "    \n",
        "# Find best performer\n",
        "if improvements:\n",
        "    best_feature, best_improvement, best_loss = max(improvements, key=lambda x: x[1])\n",
        "    print(f\"\\n🏆 BEST PERFORMER: {best_feature} ({best_improvement:+.1f}% improvement)\")\n",
        "    print(f\"   Loss: {best_loss:.6f}\")\n",
