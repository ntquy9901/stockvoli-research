      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 🤖 TimesFM Model Setup"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Import TimesFM and PEFT\n",
        "print(\"Loading TimesFM 2.5 model...\")\n",
        "from transformers import TimesFm2_5ModelForPrediction\n",
        "from peft import LoraConfig, get_peft_model\n",
        "import torch\n",
        "from torch.utils.data import DataLoader, Dataset\n",
        "\n",
        "# Set device\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "print(f\"Using device: {device}\")\n",
        "\n",
        "# Load TimesFM 2.5\n",
        "model = TimesFm2_5ModelForPrediction.from_pretrained(\n",
        "    config.model_name,\n",
        "    torch_dtype=torch.bfloat16,  # Memory efficient\n",
        "    device_map=device\n",
        ")\n",
        "\n",
        "# Get model limits\n",
        "model_context_len = model.config.context_length\n",
        "model_horizon_len = model.config.horizon_length\n",
        "print(f\"Model context length: {model_context_len}\")\n",
        "print(f\"Model horizon length: {model_horizon_len}\")\n",
        "\n",
        "# Use smaller of config and model limits\n",
        "context_len = min(config.context_length, model_context_len)\n",
        "horizon_len = min(config.horizon_length, model_horizon_len)\n",
        "\n",
        "print(f\"Actual context length: {context_len}\")\n",
        "print(f\"Actual horizon length: {horizon_len}\")\n",
        "\n",
        "print(f\"\\n✅ TimesFM 2.5 loaded successfully!\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 🔧 Dataset Creation"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Create TimesFM-compatible dataset\n",
        "print(\"Creating dataset classes...\")\n",
        "\n",
        "class TimesFMDataset(Dataset):\n",
        "    \"\"\"\n",
        "    TimesFM dataset for OHLC feature testing\n",
        "    \n",
        "    Supports multiple feature types with proper temporal split\n",
        "    \"\"\"\n",
        "    \n",
        "    def __init__(self, stock_data_dict, feature_type='RV_20', \n",
        "                 context_len=64, horizon_len=1, mode='train', \n",
        "                 samples_per_stock=200, seed=42):\n",
        "        self.context_len = context_len\n",
        "        self.horizon_len = horizon_len\n",
        "        self.mode = mode\n",
        "        self.samples_per_stock = samples_per_stock\n",
        "        self.feature_type = feature_type\n",
        "        self.seed = seed\n",
        "        \n",
        "        # Process each stock\n",
        "        self.series_list = []\n",
        "        for stock_name, df in stock_data_dict.items():\n",
        "            if self.feature_type in df.columns:\n",
        "                series_data = df[self.feature_type].dropna().values\n",
        "                \n",
        "                if len(series_data) >= context_len + horizon_len:\n",
        "                    self.series_list.append({\n",
        "                        'name': stock_name,\n",
        "                        'data': series_data,\n",
        "                        'data_len': len(series_data)\n",
        "                    })\n",
        "        \n",
        "        # Create samples with temporal split\n",
        "        self.samples = []\n",
        "        rng = np.random.default_rng(seed)\n",
        "        \n",
        "        for series_info in self.series_list:\n",
        "            series_data = series_info['data']\n",
        "            data_len = len(series_data)\n",
        "            min_len = context_len + horizon_len\n",
        "            \n",
        "            # Temporal split (80/20)\n",
        "            if mode == 'train':\n",
        "                max_start = int(data_len * 0.8) - min_len\n",
        "                if max_start < 10:\n",
        "                    continue\n",
        "                start_indices = rng.integers(0, max_start + 1, size=samples_per_stock)\n",
        "            else:  # test mode\n",
        "                min_start = int(data_len * 0.8)\n",
        "                max_start = data_len - min_len\n",
        "                if min_start >= max_start:\n",
        "                    continue\n",
        "                start_indices = rng.integers(min_start, max_start + 1, size=samples_per_stock)\n",
        "            \n",
        "            for start_idx in start_indices:\n",
        "                end = start_idx + context_len + horizon_len\n",
        "                context = series_data[start_idx:start_idx + context_len]\n",
        "                target = series_data[start_idx + context_len:end]\n",
        "                \n",
        "                self.samples.append({\n",
        "                    'context': torch.tensor(context, dtype=torch.float32),\n",
        "                    'target': torch.tensor(target, dtype=torch.float32),\n",
        "                    'stock': series_info['name']\n",
        "                \"\"\)\n",
        "        \n",
        "    def __len__(self):\n",
        "        return len(self.samples)\n",
        "    \n",
        "    def __getitem__(self, idx):\n",
        "        sample = self.samples[idx]\n",
        "        return {\n",
        "            'context': sample['context'],\n",
        "            'target': sample['target'],\n",
        "            'stock': sample['stock']\n",
        "        }\n",
        "\n",
        "# Create dataloaders for each feature\n",
        "def create_dataloaders(feature_type, config, mode='train'):\n",
        "    \"\"\"Create dataloaders for a specific feature type\"\"\"\n",
        "    # Create dataset\n",
        "    dataset = TimesFMDataset(\n",
        "        stock_data=stock_data,\n",
        "        feature_type=feature_type,\n",
        "        context_len=context_len,\n",
        "        horizon_len=horizon_len,\n",
        "        mode=mode,\n",
        "        samples_per_stock=200  # Reduced for Colab efficiency\n",
        "        seed=42\n",
        "    )\n",
        "    \n",
        "    # Create dataloader\n",
        "    dataloader = DataLoader(\n",
        "        dataset,\n",
        "        batch_size=config.batch_size,\n",
        "        shuffle=(mode == 'train'),\n",
        "        num_workers=2,  # Colab optimal\n",
        "        pin_memory=True if device.type == 'cuda' else False\n",
        "    )\n",
        "    \n",
        "    return dataloader\n",
        "\n",
        "print(\"✅ Dataset classes created successfully!\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 🔧 LoRA Configuration"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Setup LoRA adapters (Google Research configuration)\n",
        "print(\"Configuring LoRA adapters...\")\n",
        "\n",
        "lora_config = LoraConfig(\n",
        "    r=config.lora_r,                    # Rank 4 from paper\n",
        "    lora_alpha=config.lora_alpha,      # Alpha 8 from paper\n",
        "    target_modules=\"all-linear\",    # Google Research approach\n",
        "    lora_dropout=0.05,\n",
        "    bias=\"none\"\n",
        ")\n",
        "\n",
        "model = get_peft_model(model, lora_config)\n",
        "\n",
        "# Show trainable parameters\n",
        "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
        "total_params = sum(p.numel() for p in model.parameters())\n",
        "\n",
        "print(f\"LoRA adapters configured:\")\n",
        "print(f\"  Trainable params: {trainable_params:,} ({trainable_params/total_params*100:.2f}% of total)\")\n",
        "print(f\"  Total params: {total_params:,}\")\n",
        "print(f\"\\n✅ LoRA setup complete!\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 🎯 Training Functions"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Training function\n",
        "import torch.nn as nn\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "def train_feature(model, train_loader, test_loader, feature_name, config, device):\n",
        "    \"\"\"Train TimesFM on a single feature\"\"\"\n",
        "    model.train()\n",
        "    \n",
        "    # Optimizer (SGD as per financial ML best practices)\n",
        "    optimizer = torch.optim.SGD(\n",
        "        model.parameters(),\n",
        "        lr=config.learning_rate,\n",
        "        momentum=0.9,           # High momentum for stability\n",
        "        nesterov=True           # Nesterov momentum\n",
        "    )\n",
        "    \n",
        "    # Scheduler\n",
        "    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(\n",
        "        optimizer,\n",
        "        T_max=config.num_epochs * len(train_loader),\n",
        "        eta_min=1e-6\n",
        "    )\n",
        "    \n",
        "    # Training loop\n",
        "    best_val_loss = float('inf')\n",
        "    training_losses = []\n",
        "    val_losses = []\n",
        "    \n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(f\"[TRAINING] {feature_name} - {config.num_epochs} epochs\")\n",
        "    print(f\"{'='*70}\")\n",
        "    print(f\"Batch size: {config.batch_size}\")\n",
        "    print(f\"Train samples: {len(train_loader.dataset)}\")\n",
        "    print(f\"Test samples: {len(test_loader.dataset)}\")\n",
        "    print(f\"\\nExpected time: ~{config.num_epochs * 3.7:.1f} hours\")\n",
        "    print(f\"{'='*70}\\n\")\n",
        "    \n",
        "    for epoch in range(config.num_epochs):\n",
        "        epoch_loss = 0.0\n",
        "        n_batches = 0\n",
        "        \n",
        "        # Training phase\n",
        "        model.train()\n",
        "        progress_bar = tqdm(train_loader, desc=f\"Epoch {epoch+1}/{config.num_epochs}\")\n",
        "        \n",
        "        for batch in progress_bar:\n",
        "            # Move batch to device\n",
        "            context = batch['context'].to(device)\n",
        "            target = batch['target'].to(device)\n",
        "            \n",
        "            # Frequency ID (daily data = 0)\n",
        "            freq = [[0]] * context.shape[0]\n",
        "            \n",
        "            # Forward pass with loss\n",
        "            outputs = model(\n",
        "                past_values=context,\n",
        "                freq=freq,\n",
        "                future_values=target\n",
        "            )\n",
        "            \n",
        "            loss = outputs.loss\n",
        "            \n",
        "            # Backward pass\n",
        "            optimizer.zero_grad()\n",
        "            loss.backward()\n",
        "            \n",
        "            # Gradient clipping (financial ML standard)\n",
        "            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
        "            \n",
        "            # Optimizer step\n",
        "            optimizer.step()\n",
        "            scheduler.step()\n",
        "            \n",
        "            epoch_loss += loss.item()\n",
        "            n_batches += 1\n",
        "            \n",
        "        avg_train_loss = epoch_loss / max(n_batches, 1)\n",
        "        training_losses.append(avg_train_loss)\n",
        "        \n",
        "        # Validation phase\n",
        "        model.eval()\n",
        "        val_loss = 0.0\n",
        "        val_batches = 0\n",
        "        \n",
        "        with torch.no_grad():\n",
        "            for batch in test_loader:\n",
        "                context = batch['context'].to(device)\n",
        "                target = batch['target'].to(device)\n",
        "                freq = [[0]] * context.shape[0]\n",
        "                \n",
        "                outputs = model(\n",
        "                    past_values=context,\n",
        "                    freq=freq,\n",
        "                    future_values=target\n",
        "                )\n",
        "                \n",
        "                val_loss += outputs.loss.item()\n",
        "                val_batches += 1\n",
        "        \n",
        "        avg_val_loss = val_loss / max(val_batches, 1)\n",
        "        val_losses.append(avg_val_loss)\n",
        "        \n",
        "        # Save best model\n",
        "        is_best = avg_val_loss < best_val_loss\n",
        "        if is_best:\n",
        "            best_val_loss = avg_val_loss\n",
        "            \n",
        "            # Save LoRA adapter\n",
        "            save_dir = f'/content/drive/MyDrive/TimesFM_VN30/models/{feature_name}_best_adapter'\n",
        "            model.save_pretrained(save_dir)\n",
        "            \n",
        "            print(f\"  🎯 New best model! Val loss: {best_val_loss:.6f}\")\n",
        "        \n",
        "        # Epoch summary\n",
        "        print(f\"Epoch {epoch+1}/{config.num_epochs}:\")\n",
        "        print(f\"  Train Loss: {avg_train_loss:.6f}\")\n",
        "        print(f\"  Val Loss: {avg_val_loss:.6f}\")\n",
        "        print(f\"  Best Val Loss: {best_val_loss:.6f}\")\n",
        "        print(f\"  Time: {is_best}\")\n",
        "        \n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(f\"[COMPLETE] {feature_name} Training\")\n",
        "    print(f\"{'='*70}\")\n",
        "    print(f\"Final best val loss: {best_val_loss:.6f}\")\n",
        "    print(f\"Training time: {len(training_losses) * 53 / 60:.1f} minutes\")\n",
        "    \n",
        "    return {\n",
        "        'feature_type': feature_name,\n",
        "        'best_val_loss': best_val_loss,\n",
        "        'training_losses': training_losses,\n",
        "        'val_losses': val_losses,\n",
        "        'epochs_completed': config.num_epochs,\n",
        "        'training_time_minutes': len(training_losses) * 53 / 60,\n",
               'timestamp': datetime.now().isoformat()\n",
        "    }\n",
        "\n",
        "print(\"✅ Training function defined!\")"
      ]
    },
