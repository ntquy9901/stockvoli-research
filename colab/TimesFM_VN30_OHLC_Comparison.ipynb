        "    # Train model\n",
        "    result = train_feature(model, train_loader, test_loader, feature_type, config, device)\n",
        "    results[feature_type] = result\n",
        "    \n",
        "    # Small pause between features (GPU cleanup)\n",
        "    if i < len(config.features_to_test) - 1:\n",
